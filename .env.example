# ─── WhatsApp / Owner ───────────────────────────────────────────────
# Your WhatsApp number (with country code, no + or spaces)
OWNER_WA_JID=2348012345678

# ─── Telegram Bot ───────────────────────────────────────────────────
# Get from @BotFather on Telegram
TG_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram user ID (get from @userinfobot)
OWNER_TG_ID=your_telegram_id_here

# ─── MongoDB (localhost) ─────────────────────────────────────────────
MONGO_URI=mongodb://pappybot:your_password_here@127.0.0.1:27017/PappyUltimate2?authSource=admin
MONGO_DB_NAME=PappyUltimate2
MONGO_USER=pappybot
MONGO_PASSWORD=your_secure_password_here

# ─── Redis (localhost) ───────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_REQUIRE_AUTH=true

# ─── AI Providers (at least one required) ───────────────────────────
# OpenRouter (recommended - supports multiple models)
OPENROUTER_API_KEY=your_openrouter_key_here

# DigitalOcean AI (free tier available)
DIGITALOCEAN_AI_KEY=your_digitalocean_ai_key_here

# Alibaba Qwen (optional)
QWEN_API_KEY=your_qwen_key_here

# OpenAI (optional)
OPENAI_API_KEY=your_openai_key_here

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=your_anthropic_key_here

# DeepSeek (optional)
DEEPSEEK_API_KEY=your_deepseek_key_here

# NVIDIA (optional)
NVIDIA_API_KEY=your_nvidia_key_here

# ─── Node ────────────────────────────────────────────────────────────
NODE_ENV=production
